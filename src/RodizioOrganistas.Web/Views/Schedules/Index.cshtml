@model ScheduleFilterViewModel
@using RodizioOrganistas.Domain.Entities
@using RodizioOrganistas.Domain.Enums
<h3>Rodízios da Igreja</h3>
@if (User.IsInRole(nameof(UserRole.MasterAdmin)) || User.IsInRole(nameof(UserRole.ChurchAdmin)))
{
<form method="post">
<div class="row">
<div class="col-md-3"><label>Igreja</label><select asp-for="ChurchId" class="form-control" asp-items="@(new SelectList((IReadOnlyList<Church>)ViewBag.Churches, "Id", "Name"))"></select></div>
<div class="col-md-2"><label>Início</label><input asp-for="StartDate" type="date" class="form-control" /></div>
<div class="col-md-2"><label>Fim</label><input asp-for="EndDate" type="date" class="form-control" /></div>
<div class="col-md-3"><label>Tipo</label><select asp-for="ServiceType" class="form-control"><option value="@ServiceType.YouthMeeting">Reunião de Jovens</option><option value="@ServiceType.OfficialService">Cultos Oficiais</option></select></div>
</div><button class="btn btn-primary mt-2">Gerar e Salvar</button>
</form>
}

@if (Model.Results.Any()) {
<h5 class="mt-3">Prévia gerada</h5>
<table class="table table-sm"><thead><tr><th>Data</th><th>Dia</th><th>Organista</th><th>Meia Hora</th></tr></thead><tbody>
@foreach (var r in Model.Results) {<tr><td>@r.Date</td><td>@r.DayOfWeek</td><td>@r.OrganistName</td><td>@(r.HalfHourOrganistName ?? "-")</td></tr>}
</tbody></table>
}

<h5 class="mt-3">Rodízios salvos</h5>
<table class="table table-bordered"><thead><tr><th>ID</th><th>Igreja</th><th>Período</th><th>Tipo</th><th>Criado em</th><th></th></tr></thead><tbody>
@foreach (var s in Model.SavedSchedules){
<tr><td>@s.Id</td><td>@(s.Church?.Name ?? s.ChurchId.ToString())</td><td>@s.StartDate até @s.EndDate</td><td>@s.ServiceType</td><td>@s.CreatedAt.ToLocalTime()</td>
<td><a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@s.Id">Ver</a>
<a class="btn btn-sm btn-secondary" asp-action="Print" asp-route-id="@s.Id" target="_blank">Imprimir</a></td></tr>}
</tbody></table>
