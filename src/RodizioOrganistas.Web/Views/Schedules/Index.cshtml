@model ScheduleFilterViewModel
@using RodizioOrganistas.Domain.Entities
@using RodizioOrganistas.Domain.Enums
<h3>Impressão de Rodízio</h3>
<form method="post">
<div class="row">
<div class="col-md-3"><label>Igreja</label><select asp-for="ChurchId" class="form-control" asp-items="@(new SelectList((IReadOnlyList<Church>)ViewBag.Churches, "Id", "Name"))"></select></div>
<div class="col-md-2"><label>Início</label><input asp-for="StartDate" type="date" class="form-control" /></div>
<div class="col-md-2"><label>Fim</label><input asp-for="EndDate" type="date" class="form-control" /></div>
<div class="col-md-3"><label>Tipo</label><select asp-for="ServiceType" class="form-control"><option value="@ServiceType.YouthMeeting">Reunião de Jovens</option><option value="@ServiceType.OfficialService">Cultos Oficiais</option></select></div>
</div><button class="btn btn-primary mt-2">Gerar</button>
<button class="btn btn-secondary mt-2" formaction="/Schedules/Print" formtarget="_blank">Imprimir</button>
</form>
@if (Model.Results.Any()) {
<table class="table table-sm mt-3"><thead><tr><th>Data</th><th>Dia</th><th>Organista</th><th>Meia Hora</th></tr></thead><tbody>
@foreach (var r in Model.Results) {<tr><td>@r.Date</td><td>@r.DayOfWeek</td><td>@r.OrganistName</td><td>@(r.HalfHourOrganistName ?? "-")</td></tr>}
</tbody></table>
}
